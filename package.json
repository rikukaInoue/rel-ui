{
  "name": "rel-ui",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @rel-ui/docs dev",
    "test": "pnpm -r test",
    "test:vrt": "pnpm --filter @rel-ui/docs test:vrt",
